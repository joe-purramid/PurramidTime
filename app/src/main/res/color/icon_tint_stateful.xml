<?xml version="1.0" encoding="utf-8"?>
<!-- Icon tint for stateful action buttons, driven by isActivated
     (purramid_button_implementation_guide.md). Colors come from the shared
     design tokens in values/colors.xml. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true" android:color="@color/icon_state_active" />
    <item android:state_selected="true" android:color="@color/icon_state_active" />
    <item android:state_enabled="false" android:color="@color/icon_state_disabled" />
    <item android:color="@color/icon_state_inactive" />
</selector>
