<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white"
    android:elevation="4dp">

    <!-- Close button in top right -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageButton
            android:id="@+id/closeButton"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_close"
            android:background="@drawable/action_button_background"
            android:tint="@color/icon_tint_stateful"
            android:scaleType="centerInside"
            android:contentDescription="@string/close" />
    </RelativeLayout>

    <!-- Digital time display -->
    <TextView
        android:id="@+id/digitalTimeTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00.00"
        android:textSize="48sp"
        android:textColor="@android:color/black"
        android:fontFamily="monospace"
        android:layout_gravity="center_horizontal"
        android:layout_marginVertical="16dp" />

    <!-- Control buttons row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal">

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_settings"
            android:background="@drawable/action_button_background"
            android:tint="@color/icon_tint_stateful"
            android:scaleType="centerInside"
            android:contentDescription="@string/settings" />

        <!-- Play/Pause button -->
        <ImageButton
            android:id="@+id/playPauseButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_play"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/action_button_background"
            android:tint="@color/icon_tint_stateful"
            android:scaleType="centerInside"
            android:contentDescription="@string/play" />

        <!-- Lap/Reset button - Initially hidden -->
        <ImageButton
            android:id="@+id/lapResetButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_reset"
            android:background="@drawable/action_button_background"
            android:tint="@color/icon_tint_stateful"
            android:scaleType="centerInside"
            android:visibility="gone"
            android:contentDescription="@string/reset" />
    </LinearLayout>

    <!-- Lap times display - Initially hidden -->
    <LinearLayout
        android:id="@+id/lapTimesLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lap"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/noLapsTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_laps_recorded"
            android:textSize="14sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/lapTimesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    </LinearLayout>

</LinearLayout>
