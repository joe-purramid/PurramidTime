<?xml version="1.0" encoding="utf-8"?>
<!-- ClockActivity is a transparent shim (Theme.Transparent): it starts
     ClockOverlayService and finishes, or hosts ClockSettingsFragment as a dialog.
     It draws no clock of its own — the overlay window the service owns is the
     clock. This root exists only to anchor snackbars, matching activity_timer.xml
     and activity_stopwatch.xml.

     It previously held a full-screen clock UI (ClockView, play/pause/reset, close,
     settings) left over from before the overlay service existed. None of it was
     wired to a listener and the activity finishes on launch, so none of it ever
     reached the screen. Removed rather than restyled. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent" />
