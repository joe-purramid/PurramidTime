<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.purramid.purramidtime">

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:name=".PurramidTimeApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/purramidtime_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/purramidtime_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.PurramidTime">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PurramidTime.Floating"
            android:resizeableActivity="true"
            android:windowLayoutInDisplayCutoutMode="shortEdges">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <layout
                android:defaultWidth="200dp"
                android:defaultHeight="200dp"
                android:gravity="center" />
        </activity>

        <!-- CLOCK -->
        <activity android:name=".clock.ClockActivity"
            android:exported="false"
            android:label="@string/clock_title"
            android:theme="@style/Theme.Transparent"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:parentActivityName=".MainActivity"
            android:resizeableActivity="true"
            android:windowLayoutInDisplayCutoutMode="shortEdges">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <layout android:defaultWidth="420dp"
                android:defaultHeight="300dp"
                android:gravity="center" />
        </activity>

        <service android:name=".clock.ClockOverlayService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="persistent_classroom_overlay" />
        </service>

        <activity android:name=".clock.ui.TimeZoneGlobeActivity"
            android:exported="false"
            android:label="@string/set_time_zone"
            android:parentActivityName=".clock.ClockActivity"
            android:resizeableActivity="true"
            android:windowLayoutInDisplayCutoutMode="shortEdges">
            <layout android:defaultWidth="1000dp"
                android:defaultHeight="750dp"
                android:gravity="center" />
        </activity>

        <!-- STOPWATCH -->
        <activity android:name=".stopwatch.StopwatchActivity"
            android:exported="false"
            android:label="@string/stopwatch_title"
            android:theme="@style/Theme.Transparent"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:parentActivityName=".MainActivity"
            android:resizeableActivity="true"
            android:windowLayoutInDisplayCutoutMode="shortEdges">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <layout android:defaultWidth="420dp"
                android:defaultHeight="300dp"
                android:gravity="center" />
        </activity>

        <service android:name=".stopwatch.StopwatchService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="persistent_classroom_overlay" />
        </service>

        <!-- TIMER -->
        <activity android:name=".timer.TimerActivity"
            android:exported="false"
            android:label="@string/timer_title"
            android:theme="@style/Theme.Transparent"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:parentActivityName=".MainActivity"
            android:resizeableActivity="true"
            android:windowLayoutInDisplayCutoutMode="shortEdges">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <layout android:defaultWidth="420dp"
                android:defaultHeight="300dp"
                android:gravity="center" />
        </activity>

        <service android:name=".timer.TimerService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="persistent_classroom_overlay" />
        </service>

        <!-- ABOUT -->
        <activity android:name=".AboutActivity"
            android:exported="false"
            android:label="@string/about"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.AppCompat.Light.Dialog"
            android:resizeableActivity="true"
            android:windowLayoutInDisplayCutoutMode="shortEdges">
            <layout android:defaultWidth="600dp"
                android:defaultHeight="500dp"
                android:gravity="center" />
        </activity>

        <!-- WIDGET -->
        <receiver android:name=".PurramidWidgetProvider"
            android:exported="false"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/purramid_widget_info" />
        </receiver>
        <activity
            android:name=".WidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Dialog">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE"/>
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>